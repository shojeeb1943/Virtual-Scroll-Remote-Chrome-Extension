{
  "manifest_version": 3,
  "name": "Virtual Scroll Remote",
  "version": "1.0.0",
  "description": "A digital alternative to a physical mouse scroll wheel with customizable trigger zones",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Virtual Scroll Remote"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}